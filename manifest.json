{
  "manifest_version": 3,
  "name": "KeepTabs",
  "version": "0.1.0",
  "description": "Sekmelerini klasörlere kaydet, kapat, sonra geri aç. Hesap yok, sunucu yok — verin sizde kalır.",
  "permissions": ["tabs", "storage"],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "KeepTabs",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png"
    }
  }
}
