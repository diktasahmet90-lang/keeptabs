{
  "manifest_version": 3,
  "name": "KeepTabs",
  "version": "0.1.1",
  "description": "Save tabs into named folders, close them, and reopen anytime. No account, no servers — your data stays on your device.",
  "permissions": ["tabs", "storage"],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "KeepTabs",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png"
    }
  }
}
